# YouTube Data API v3 key
# https://console.cloud.google.com → APIs & Services → Credentials → Create API key
YOUTUBE_API_KEY=

# YouTube channel handle (sin @, ej. "Javi-Tech")
YOUTUBE_HANDLE=Javi-Tech

# Instagram handle (sin @)
INSTAGRAM_HANDLE=javimendozayt

# Fallback manual de seguidores IG. Se usa solo si el scraping falla
# (típicamente desde IPs de datacenter como Hetzner, donde Meta redirige a login).
# Déjalo vacío en local; ponlo en producción y actualízalo cuando quieras.
INSTAGRAM_FALLBACK=

# Password para acceder al dashboard /stats (HTTP basic auth, cualquier usuario).
# Déjalo vacío para deshabilitar el dashboard (devuelve 401).
STATS_PASSWORD=

# Ruta del SQLite del tracker. En producción debe apuntar a un volumen persistente.
# En local puedes dejarlo en blanco y se creará en /app/data/tracker.db (o cambiarlo a ./tracker.db).
TRACKER_DB=
